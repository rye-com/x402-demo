# Rye API (used by demos/rye-x402-demo)
CHECKOUT_INTENTS_API_KEY=your_api_key_here

# x402 proxy URL (used by demos/x402-proxy-demo)
# Defaults to LOCAL_PROXY_URL when running against a local proxy (cd ../x402-proxy && pnpm dev).
# Set X402_PROXY_URL to point at a deployed proxy instead.
LOCAL_PROXY_URL=http://localhost:3000
X402_PROXY_URL=https://x402.rye.com

# Agent wallets — shared across all demos; set whichever networks you plan to use
# Base / EVM (generate with: npm run generate-wallet)
AGENT_PRIVATE_KEY=0x...

# Solana (generate with: npm run generate-wallet solana)
AGENT_SOLANA_PRIVATE_KEY=
